# Copy to .env before running docker compose.
# Never commit real values.

# n8n runtime
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/New_York
TZ=America/New_York
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
N8N_USER_MANAGEMENT_DISABLED=false
N8N_DIAGNOSTICS_ENABLED=false
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_RUNNERS_ENABLED=true

# Postgres backing store
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-me

# Optional workflow-level API keys referenced directly by JSON expressions.
# Most credentials should be configured inside n8n Credentials after import.
APOLLO_API_KEY=
LINEAR_API_KEY=

# Local helper services used by selected workflows.
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
REDIS_URL=redis://redis:6379


{
  "name": "GTM 12 — Account-Based Intent Signal Engine",
  "nodes": [
    {
      "parameters": {
        "content": "## Live deployment checklist\n\nWorkflow: GTM 12 — Account-Based Intent Signal Engine\nNodes: 14\nTrigger: Daily 7am, Trigger Retarget Ad\nCredentials/services: Google Sheets, HubSpot, OpenAI, Slack OAuth\nPlaceholders: #abm, YOUR_GA_PROP, YOUR_SHEET_ID\nEnvironment variables: None detected\nExternal webhook setup: not required\n\nBefore activating:\n1. Configure every credential in n8n Credentials.\n2. Replace every placeholder above with live IDs, channels, folders, or database IDs.\n3. Execute once with test data and inspect every node output.\n4. Activate only after the workflow reaches its final node successfully.",
        "height": 440,
        "width": 520,
        "color": 4
      },
      "id": "live-033b8627cc0d8c1cbd2d5a63",
      "name": "Live Deployment Checklist",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        80,
        -140
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 7 * * *"
            }
          ]
        }
      },
      "id": "f7888f66-d59d-496a-b1e5-fe4fc2134a8e",
      "name": "Daily 7am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        200,
        400
      ]
    },
    {
      "parameters": {
        "url": "https://data.g2.com/api/v1/buyer-intent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "c7a37fd1-c2c7-404f-ba36-f18a2d2ccb1a",
      "name": "G2 Intent API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        400,
        250
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://analyticsdata.googleapis.com/v1beta/properties/YOUR_GA_PROP:runReport",
        "sendBody": true,
        "jsonBody": "={\n \"dateRanges\":[{\"startDate\":\"yesterday\",\"endDate\":\"yesterday\"}],\n \"dimensions\":[{\"name\":\"pagePath\"},{\"name\":\"city\"}],\n \"metrics\":[{\"name\":\"activeUsers\"}]\n}"
      },
      "id": "40bcd996-8d4a-41e6-a088-df8cbe30ec4f",
      "name": "GA4 Page Visits",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        400,
        400
      ]
    },
    {
      "parameters": {
        "url": "https://api.linkedin.com/v2/adAnalyticsV2"
      },
      "id": "c4add9b6-6d32-4df7-8a5c-b2b14623fc6a",
      "name": "LinkedIn Ad Clicks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        400,
        550
      ]
    },
    {
      "parameters": {
        "mode": "append"
      },
      "id": "204e5e53-1818-494b-9baf-21a2243f7b4f",
      "name": "Merge Signals",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        650,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "// group raw signals by account_domain\nconst byAcct={};\nfor(const i of $input.all()){\n const j=i.json;\n const d=j.account_domain||j.company||j.dimensionValues?.[0]?.value||'unknown';\n byAcct[d]=byAcct[d]||{domain:d,signals:[]};\n byAcct[d].signals.push(j);\n}\nreturn Object.values(byAcct).map(x=>({json:x}));"
      },
      "id": "e4ff44ae-6527-482f-806f-63c755d1dfd8",
      "name": "Normalize per Account",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        850,
        400
      ]
    },
    {
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "__rl": true,
          "value": "gpt-4o",
          "mode": "list"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Given mixed buying signals for an account, return JSON {score:0-100, primary_signal, recommended_channel:email|linkedin|ad, recommended_message_angle}."
            },
            {
              "content": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "jsonOutput": true
      },
      "id": "7aca897a-1f0e-437f-9920-409000e15817",
      "name": "GPT Intent Score",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        1050,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {},
          "conditions": [
            {
              "id": "1bea3328-720d-4fff-84a1-3721c580a3c8",
              "leftValue": "={{ $json.message.content.score }}",
              "rightValue": 80,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ]
        }
      },
      "id": "f486e1ca-fc67-45fb-b7bc-3f546e85b936",
      "name": "Score >= 80?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1250,
        400
      ]
    },
    {
      "parameters": {
        "mode": "expression",
        "output": "input",
        "rules": {
          "rules": [
            {
              "value2": "email"
            },
            {
              "value2": "linkedin"
            },
            {
              "value2": "ad"
            }
          ]
        },
        "value1": "={{ $json.message.content.recommended_channel }}"
      },
      "id": "144c6477-f2ce-4c5f-8b4c-ec1afc904fad",
      "name": "Switch by Channel",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        1450,
        300
      ]
    },
    {
      "parameters": {
        "resource": "deal",
        "operation": "update",
        "dealId": "={{ $('Normalize per Account').item.json.domain }}",
        "updateFields": {
          "customProperties": {
            "customProperty": [
              {
                "property": "intent_score",
                "value": "={{ $('GPT Intent Score').item.json.message.content.score }}"
              }
            ]
          }
        }
      },
      "id": "99b2d9a3-1c84-4481-a33e-55aa9807b11e",
      "name": "HubSpot Update Account",

          "value": "#abm",
          "mode": "name"
        },
        "text": "=:dart: High-intent account: {{ $('Normalize per Account').item.json.domain }} (score {{ $('GPT Intent Score').item.json.message.content.score }}). Angle: {{ $('GPT Intent Score').item.json.message.content.recommended_message_angle }}"
      },
      "id": "7e44c9e0-1db9-48b1-bb62-f96fc8184de5",

      "name": "Merge Sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        600,
        250
      ]
    },
    {
      "parameters": {
        "jsCode": "const crypto=require('crypto');\nconst items=$input.all().map(i=>{\n  const j=i.json;\n  const text=j.text||j.transcript||j.snippet||j.body||'';\n  const id=crypto.createHash('sha1').update(text).digest('hex');\n  return {json:{id, text:text.slice(0,4000), source:j.source_type||'unknown', ts:j.ts||new Date().toISOString()}};\n});\nreturn items.filter(i=>i.json.text.length>50);"
      },
      "id": "e695fb23-1c25-4787-abe9-019c2a0d7c13",
      "name": "Normalize + Hash",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        250
      ]
    },

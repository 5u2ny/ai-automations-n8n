      "typeVersion": 2,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Classify ticket: intent (billing|bug|how-to|cancel|other), urgency (high|med|low), sentiment (pos|neu|neg). Return JSON."
            },
            {
              "content": "={{ $json.body.ticket.subject }}\n\n{{ $json.body.ticket.description }}"
            }
          ]
        },
        "jsonOutput": true
      },
      "id": "8c58a240-f882-4ed8-80e4-a4e2bc99b958",
      "name": "GPT Classify",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "resource": "ticket",
        "operation": "update",
        "id": "={{ $('Zendesk Webhook').item.json.body.ticket.id }}",
        "updateFields": {
          "tags": "={{ [$json.message.content.intent, $json.message.content.urgency, $json.message.content.sentiment].join(',') }}",
          "priority": "={{ $json.message.content.urgency==='high'?'urgent':($json.message.content.urgency==='med'?'normal':'low') }}"
        }
      },
      "id": "cdce0eee-2728-4d9f-956f-654f79ed8dd3",

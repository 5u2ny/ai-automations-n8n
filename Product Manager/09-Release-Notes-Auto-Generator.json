        "resource": "message",
        "operation": "post",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "general",
          "mode": "name"
        },
        "text": "=:tada: *Shipped this week*\n\n{{ $('Internal Version').item.json.message.content }}"
      },
      "id": "309cf29f-1b41-479a-a769-db5a59ae8c4f",
      "name": "Slack #general",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [

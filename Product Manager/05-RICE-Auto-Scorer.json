      "typeVersion": 1.8,
      "position": [
        1200,
        400
      ]
    },
    {
      "parameters": {
        "resource": "databasePage",
        "operation": "update",
        "pageId": "={{ $('Get Idea').item.json.id }}",
        "propertiesUi": {
          "propertyValues": [
            {
              "key": "Reach|number",
              "numberValue": "={{ $json.message.content.reach }}"
            },
            {
              "key": "Impact|number",
              "numberValue": "={{ $json.message.content.impact }}"
            },
            {
              "key": "Confidence|number",
              "numberValue": "={{ $json.message.content.confidence }}"
            },
            {
              "key": "Effort|number",
              "numberValue": "={{ $json.message.content.effort_person_months }}"
            },
            {
              "key": "RICE|number",
              "numberValue": "={{ $json.message.content.rice_score }}"
            },
            {
              "key": "Reasoning|rich_text",
              "textContent": "={{ $json.message.content.reasoning }}"
            }
          ]
        }
      },
      "id": "56fbcfe9-8a08-45a0-9ebc-46eeb100d0f7",
      "name": "Update Notion RICE",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [
        1400,
        400
      ]
    },
    {
      "parameters": {

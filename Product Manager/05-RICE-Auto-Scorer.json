          "options": {},
          "conditions": [
            {
              "id": "139b9b9b-32b9-44e0-b275-74366ce3b993",
              "leftValue": "={{ $('Compute RICE').item.json.message.content.rice_score }}",
              "rightValue": 50,
              "operator": {
                "type": "number",
                "operation": "gte"

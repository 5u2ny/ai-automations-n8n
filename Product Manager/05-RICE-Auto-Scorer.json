{
  "name": "PM 05 — RICE Auto-Scorer",
  "nodes": [
    {
      "parameters": {
        "content": "## Live deployment checklist\n\nWorkflow: PM 05 — RICE Auto-Scorer\nNodes: 11\nTrigger: Notion Idea Created\nCredentials/services: Google Sheets, Linear API, Notion, OpenAI, OpenAI embeddings, Qdrant, Slack OAuth\nPlaceholders: YOUR_ARR_SHEET\nEnvironment variables: LINEAR_API_KEY\nExternal webhook setup: register production URL for Notion Idea Created\n\nBefore activating:\n1. Configure every credential in n8n Credentials.\n2. Replace every placeholder above with live IDs, channels, folders, or database IDs.\n3. Execute once with test data and inspect every node output.\n4. Activate only after the workflow reaches its final node successfully.",
        "height": 440,
        "width": 520,
        "color": 4
      },
      "id": "live-634cfff4c7b134fcb7fb68d9",
      "name": "Live Deployment Checklist",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        80,
        -140
      ]
    },
    {
      "parameters": {
        "path": "notion-idea",
        "httpMethod": "POST",
        "responseMode": "onReceived"
      },
      "id": "c803c9d2-e4ce-4669-8542-1060698e7e0e",
      "name": "Notion Idea Created",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        200,
        400
      ]
    },
    {
      "parameters": {
        "resource": "databasePage",
        "operation": "get",
        "pageId": "={{ $json.body.page_id }}"
      },
      "id": "b6751e2f-970f-40d7-a35c-1d1adee772bf",
      "name": "Get Idea",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [
        400,
        400
      ]
    },
    {
      "parameters": {
        "model": "text-embedding-3-small"
      },
      "id": "488814c7-a194-4e06-8854-ce1a6137b69c",
      "name": "Embed Idea",
      "type": "@n8n/n8n-nodes-langchain.embeddingsOpenAi",
      "typeVersion": 1,
      "position": [
        600,
        400
      ]
    },
    {
      "parameters": {
        "mode": "load",
        "qdrantCollection": {
          "__rl": true,
          "value": "feedback_index",
          "mode": "list"
        },
        "prompt": "={{ $('Get Idea').item.json.properties.Name.title[0].plain_text }}",
        "topK": 20
      },
      "id": "dce40050-87c2-4721-b23b-98a5b14d084b",
      "name": "Related Feedback Hits",
      "type": "@n8n/n8n-nodes-langchain.vectorStoreQdrant",
      "typeVersion": 1,
      "position": [
        800,
        250
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.linear.app/graphql",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ $env.LINEAR_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "jsonBody": "={\n \"query\":\"query($s:String!){ issues(filter:{title:{contains:$s}}){nodes{id estimate priority}} }\",\n \"variables\":{\"s\":\"{{ $('Get Idea').item.json.properties.Name.title[0].plain_text }}\"}\n}"
      },
      "id": "7657e373-2841-410d-b27e-41fa01bec2cb",
      "name": "Linked Tickets Count",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        800,
        400
      ]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "YOUR_ARR_SHEET",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "AccountRequests",
          "mode": "name"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "feature",
              "lookupValue": "={{ $('Get Idea').item.json.properties.Name.title[0].plain_text }}"
            }
          ]
        }
      },
      "id": "53a54b10-f213-448f-b157-ab4fe360cc3e",
      "name": "Revenue Tied (Sheet)",

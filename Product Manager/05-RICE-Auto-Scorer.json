          "value": "gpt-4o",
          "mode": "list"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Compute RICE score. Return JSON {reach:int, impact:0.25|0.5|1|2|3, confidence:0-100, effort_person_months:float, rice_score:float, reasoning, top_evidence:[3 quotes]}."
            },
            {
              "content": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "jsonOutput": true
      },
      "id": "ba363fc5-e81f-4bd8-8dcd-6abb68b20215",
      "name": "Compute RICE",
